# ── Database (PostgreSQL) ──
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DB]"
DIRECT_URL="postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DB]"

# ── Keamanan Sistem ──
ADMIN_KEY="your_admin_key_here"
NEXT_PUBLIC_ADMIN_KEY="your_admin_key_here"
CRON_SECRET="your_cron_secret_here"
JWT_SECRET="your_secure_jwt_secret_here"

# ── Konfigurasi Aplikasi ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

# ── Sentry Error Tracking (Opsional) ──
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ── MongoDB (Example) ──
MONGODB_URI="mongodb+srv://[USER]:[PASSWORD]@[CLUSTER].mongodb.net/[DB]?retryWrites=true&w=majority"

# ── Redis (Example) ──
REDIS_URL="rediss://default:[PASSWORD]@[ENDPOINT]:[PORT]"
