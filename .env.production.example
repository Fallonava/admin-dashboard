# ============================================
# PRODUCTION ENV EXAMPLE
# Copy → .env.production (atau isi di panel env server)
# Jangan pernah commit file berisi nilai asli!
# ============================================

# ── Database (Neon PostgreSQL) ─────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST_POOLER_REGION.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST_REGION.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST_REGION.neon.tech/DB?sslmode=require"

# ── Auth & Security ────────────────────────
ADMIN_KEY="CHANGE_ME_ADMIN_KEY_PROD"
NEXT_PUBLIC_ADMIN_KEY="CHANGE_ME_ADMIN_KEY_PROD"
CRON_SECRET="CHANGE_ME_CRON_SECRET_PROD"
JWT_SECRET="CHANGE_ME_JWT_SECRET_PROD"

# ── Redis (opsional, untuk cache RBAC) ────
# REDIS_URL="rediss://:PASSWORD@ENDPOINT.upstash.io:6379"

# ── App URL ────────────────────────────────
NEXT_PUBLIC_APP_URL="https://medcore.fallonava.my.id"
NODE_ENV="production"
