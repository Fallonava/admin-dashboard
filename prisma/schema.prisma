generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id                 String         @id @default(cuid())
  name               String
  specialty          String
  status             DoctorStatus   @default(LIBUR)
  image              String?
  category           String
  startTime          String
  endTime            String
  queueCode          String
  order              Int            @default(0)
  lastCall           String?
  registrationTime   String?
  lastManualOverride BigInt?
  leaveRequests      LeaveRequest[]
  shifts             Shift[]
}

model Shift {
  id               String        @id @default(cuid())
  dayIdx           Int
  timeIdx          Int
  title            String
  color            String
  formattedTime    String?
  registrationTime String?
  extra            String?
  disabledDates    String[]
  statusOverride   DoctorStatus?
  doctorId         String
  doctor           Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([dayIdx, doctorId])
}

model LeaveRequest {
  id        String    @id @default(cuid())
  specialty String?
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    String
  avatar    String?
  doctorId  String
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([startDate, endDate])
}

model BroadcastRule {
  id         String     @id @default(cuid())
  message    String
  alertLevel AlertLevel
  targetZone TargetZone
  duration   Int
  active     Boolean
}

model AutomationRule {
  id        String   @id @default(cuid())
  name      String
  condition Json
  action    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationLog {
  id        String   @id @default(cuid())
  type      String
  details   Json?
  createdAt DateTime @default(now())
}

model Settings {
  id                String   @id @default("1")
  automationEnabled Boolean  @default(false)
  runTextMessage    String?
  emergencyMode     Boolean? @default(false)
  customMessages    Json?
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  name          String
  isActive      Boolean        @default(true)
  roleId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLogin     DateTime?
  refreshTokens RefreshToken[]
  role          Role?          @relation(fields: [roleId], references: [id])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  id       String @id @default(cuid())
  resource String
  action   String
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

enum DoctorStatus {
  TERJADWAL
  PENDAFTARAN
  PRAKTEK
  PENUH
  OPERASI
  CUTI
  SELESAI
  LIBUR
}

enum LeaveType {
  Sakit
  Liburan
  Pribadi
  Konferensi
  Lainnya
}

enum AlertLevel {
  Information
  Warning
  Critical
}

enum TargetZone {
  All_Zones  @map("All Zones")
  Lobby_Only @map("Lobby Only")
  ER_Wards   @map("ER & Wards")
}
