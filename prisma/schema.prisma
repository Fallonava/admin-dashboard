generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id                 String         @id @default(cuid())
  name               String
  specialty          String
  status             DoctorStatus   @default(LIBUR)
  image              String?
  category           String
  startTime          String
  endTime            String
  queueCode          String
  order              Int            @default(0)
  lastCall           String?
  registrationTime   String?
  lastManualOverride BigInt?
  leaveRequests      LeaveRequest[]
  shifts             Shift[]
}

model Shift {
  id               String        @id @default(cuid())
  dayIdx           Int
  timeIdx          Int
  title            String
  color            String
  formattedTime    String?
  registrationTime String?
  extra            String?
  disabledDates    String[]
  statusOverride   DoctorStatus?
  doctorId         String
  doctor           Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([dayIdx, doctorId])
}

model LeaveRequest {
  id        String    @id @default(cuid())
  specialty String?
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    String
  avatar    String?
  doctorId  String
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([startDate, endDate])
}

model BroadcastRule {
  id         String     @id @default(cuid())
  message    String
  alertLevel AlertLevel
  targetZone TargetZone
  duration   Int
  active     Boolean
}

model AutomationRule {
  id        String   @id @default(cuid())
  name      String
  condition Json
  action    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationLog {
  id        String   @id @default(cuid())
  type      String
  details   Json?
  createdAt DateTime @default(now())
}

model Settings {
  id                String   @id @default("1")
  automationEnabled Boolean  @default(false)
  runTextMessage    String?
  emergencyMode     Boolean? @default(false)
  customMessages    Json?
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  name          String
  isActive      Boolean        @default(true)
  roleId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLogin     DateTime?
  refreshTokens RefreshToken[]
  role          Role?          @relation(fields: [roleId], references: [id])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  id       String @id @default(cuid())
  resource String
  action   String
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ── JADWAL TPPRJ ────────────────────────────────────────
model StaffShiftConfig {
  id         String   @id           // stable key e.g. "s1"
  staffName  String
  cycle      Json                   // string[] - 10-day working day cycle
  isSpecial  Boolean  @default(false)
  sortOrder  Int      @default(0)
  updatedAt  DateTime @updatedAt

  overrides  ShiftOverride[]
}

model ShiftOverride {
  id          String           @id @default(cuid())
  staffId     String
  dateStr     String           // format yyyy-MM-dd
  shiftValue  String           // CT | L | P6 | CLEAR | etc.
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  staff       StaffShiftConfig @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dateStr])
  @@index([staffId])
  @@index([dateStr])
}

enum DoctorStatus {
  TERJADWAL
  PENDAFTARAN
  PRAKTEK
  PENUH
  OPERASI
  CUTI
  SELESAI
  LIBUR
}

enum LeaveType {
  Sakit
  Liburan
  Pribadi
  Konferensi
  Lainnya
}

enum AlertLevel {
  Information
  Warning
  Critical
}

enum TargetZone {
  All_Zones  @map("All Zones")
  Lobby_Only @map("Lobby Only")
  ER_Wards   @map("ER & Wards")
}

// ─── Recap & Broadcast (Migrated from MongoDB) ──────────────────────────────

model DailyRecap {
  id                  String   @id @default(cuid())
  date                DateTime @unique
  total_patients      Int      @default(0)
  missing_sep_count   Int      @default(0)
  staff_performance   Json     @default("[]")
  missing_sep_details Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BroadcastQueue {
  id             String          @id @default(cuid())
  patientName    String
  whatsappNumber String
  doctorName     String?
  clinicName     String?
  status         BroadcastStatus @default(PENDING)
  messageText    String
  log            String?
  sendAt         DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum BroadcastStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}
